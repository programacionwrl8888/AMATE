export interface ThemeClassSet {
  primaryBg: string;
  primaryHover: string;
  primaryBorder: string;
  textAccent: string;
  badgeBg: string;
  badgeBorder: string;
  badgeText: string;
  gradientFrom: string;
}

export function getThemeClasses(color: string): ThemeClassSet {
  switch (color) {
    case "emerald":
      return {
        primaryBg: "bg-emerald-600",
        primaryHover: "hover:bg-emerald-500",
        primaryBorder: "border-emerald-500/20",
        textAccent: "text-emerald-400",
        badgeBg: "bg-emerald-950/80",
        badgeBorder: "border-emerald-800",
        badgeText: "text-emerald-300",
        gradientFrom: "from-emerald-900/40",
      };
    case "indigo":
      return {
        primaryBg: "bg-indigo-600",
        primaryHover: "hover:bg-indigo-500",
        primaryBorder: "border-indigo-500/20",
        textAccent: "text-indigo-400",
        badgeBg: "bg-indigo-950/80",
        badgeBorder: "border-indigo-800",
        badgeText: "text-indigo-300",
        gradientFrom: "from-indigo-900/40",
      };
    case "rose":
      return {
        primaryBg: "bg-rose-600",
        primaryHover: "hover:bg-rose-500",
        primaryBorder: "border-rose-500/20",
        textAccent: "text-rose-400",
        badgeBg: "bg-rose-950/80",
        badgeBorder: "border-rose-800",
        badgeText: "text-rose-300",
        gradientFrom: "from-rose-900/40",
      };
    case "cyan":
      return {
        primaryBg: "bg-cyan-600",
        primaryHover: "hover:bg-cyan-500",
        primaryBorder: "border-cyan-500/20",
        textAccent: "text-cyan-400",
        badgeBg: "bg-cyan-950/80",
        badgeBorder: "border-cyan-800",
        badgeText: "text-cyan-300",
        gradientFrom: "from-cyan-900/40",
      };
    case "amber":
      return {
        primaryBg: "bg-amber-600",
        primaryHover: "hover:bg-amber-500",
        primaryBorder: "border-amber-500/20",
        textAccent: "text-amber-400",
        badgeBg: "bg-amber-950/80",
        badgeBorder: "border-amber-800",
        badgeText: "text-amber-300",
        gradientFrom: "from-amber-900/40",
      };
    case "violet":
      return {
        primaryBg: "bg-violet-600",
        primaryHover: "hover:bg-violet-500",
        primaryBorder: "border-violet-500/20",
        textAccent: "text-violet-400",
        badgeBg: "bg-violet-950/80",
        badgeBorder: "border-violet-800",
        badgeText: "text-violet-300",
        gradientFrom: "from-violet-900/40",
      };
    default:
      return {
        primaryBg: "bg-blue-600",
        primaryHover: "hover:bg-blue-500",
        primaryBorder: "border-blue-500/20",
        textAccent: "text-blue-400",
        badgeBg: "bg-blue-950/80",
        badgeBorder: "border-blue-800",
        badgeText: "text-blue-300",
        gradientFrom: "from-blue-900/40",
      };
  }
}

